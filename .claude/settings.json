{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "deny": [
      "Read(/memory-bank-template)",
      "Read(/clinerules-bank)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development.local)",
      "Read(**/.env.test.local)",
      "Read(**/.env.production.local)",
      "Read(/convert2md_scripts/.venv)",
      "Read(/convert2md_scripts/設計書)",
      "Read(/convert2md_scripts/excel2md_batch.py)",
      "Read(/convert2md_scripts/PROXY_SETUP_GUIDE.md)",
      "Read(/convert2md_scripts/README.md)",
      "Read(/convert2md_scripts/run.cmd)",
      "Read(/convert2md_scripts/requirements.txt)",
      "Read(/target)",
      "Read(/pom.xml.tag)",
      "Read(/pom.xml.releaseBackup)",
      "Read(/pom.xml.versionsBackup)",
      "Read(/pom.xml.next)",
      "Read(/release.properties)",
      "Read(/dependency-reduced-pom.xml)",
      "Read(/buildNumber.properties)",
      "Read(/.mvn/timing.properties)",
      "Read(/.mvn/wrapper/maven-wrapper.jar)",
      "Read(**/*.class)",
      "Read(**/*.jar)",
      "Read(**/*.war)",
      "Read(**/*.ear)",
      "Read(**/*.nar)",
      "Read(**/hs_err_pid*)",
      "Read(**/replay_pid*)",
      "Read(/.idea)",
      "Read(**/*.iws)",
      "Read(**/*.iml)",
      "Read(**/*.ipr)",
      "Read(**/.apt_generated)",
      "Read(**/.classpath)",
      "Read(**/.factorypath)",
      "Read(**/.project)",
      "Read(**/.settings)",
      "Read(**/.springBeans)",
      "Read(**/.sts4-cache)",
      "Read(/.vscode)",
      "Read(**/*.code-workspace)",
      "Read(**/.DS_Store)",
      "Read(**/.DS_Store?)",
      "Read(**/._*)",
      "Read(**/.Spotlight-V100)",
      "Read(**/.Trashes)",
      "Read(**/ehthumbs.db)",
      "Read(**/Thumbs.db)",
      "Read(**/*.swp)",
      "Read(**/*.swo)",
      "Read(**/*~)",
      "Read(/logs)",
      "Read(**/*.log)",
      "Read(**/*.log.*)",
      "Read(/temp)",
      "Read(/tmp)",
      "Read(**/*.db)",
      "Read(**/*.trace.db)",
      "Read(**/*.lock.db)",
      "Read(**/application-local.yml)",
      "Read(**/application-dev.yml)",
      "Read(**/application-prod.yml)",
      "Read(/upload-temp)",
      "Read(/.cache)",
      "Read(/node_modules)",
      "Read(**/checkstyle-cachefile)",
      "Read(**/checkstyle-result.xml)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/consult-on-prompt.sh\"",
            "timeout": 10,
            "statusMessage": "Checking knowledge/ for this trouble..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/consult-on-failure.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/save-nudge-on-stop.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
